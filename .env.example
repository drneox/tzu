# TZU - Environment Variables Template
# Copy this file to .env and update with your values

# AI Integration (REQUIRED)
#
# AI_MODEL  → protocolo de comunicación (provider_id) + nombre del modelo
# AI_API_BASE → URL base del proveedor (a dónde se envía el request)
#
# El provider_id NO es el destino: define el formato del request HTTP.
# Si el proveedor es compatible con OpenAI, usa provider_id=openai y
# apunta AI_API_BASE a su endpoint.
#
# Formato: <provider_id>/<model_id>
#
# --- OpenAI (directo, AI_API_BASE no necesario) ---
#   AI_MODEL=openai/gpt-4o
#   AI_MODEL=openai/gpt-4o-mini
#
# --- Anthropic (directo, AI_API_BASE no necesario) ---
#   AI_MODEL=anthropic/claude-opus-4-7
#   AI_MODEL=anthropic/claude-sonnet-4-6
#
# --- GLM / Z.ai (compatible con OpenAI) ---
#   AI_MODEL=openai/glm-5.1
#   AI_API_BASE=https://api.z.ai/api/coding/paas/v4
#
# --- Modelo local / proxy OpenAI-compatible (ej. Ollama) ---
#   AI_MODEL=openai/<nombre-del-modelo>
#   AI_API_BASE=http://localhost:11434/v1
#
AI_MODEL=openai/gpt-4o

# URL base del proveedor. Obligatorio cuando el proveedor usa un endpoint
# distinto al oficial (ej. GLM, proxies, modelos locales).
AI_API_BASE=

# API Key del proveedor definido en AI_MODEL
AI_API_KEY=your_api_key_here

# Timezone configuration
TZ=America/Lima

# TZU API Security Configuration (OPTIONAL - will be auto-generated if not provided)
#SECRET_KEY=your_secret_key_here_at_least_32_characters_long
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# Environment Configuration
ENVIRONMENT=development

# Note: Database configuration is handled automatically by Docker Compose
# No need to configure DATABASE_URL, POSTGRES_* variables manually
